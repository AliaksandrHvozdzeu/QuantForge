# =============================================================================
# QuantForge — GitHub publish (do not commit secrets, models, or local artifacts)
# =============================================================================

# --- Secrets and local overrides ---
config.ps1
.env
.env.*
*.pem
*.key
secrets/

# --- Generated config ---
config/generated/

# --- Logs and locks ---
logs/**
!logs/.gitkeep
*.log
.pipeline.lock

# --- Models (HF weights, GGUF, caches — multi‑GB) ---
models/**
!models/.gitkeep

# Hugging Face download cache (anywhere in tree)
**/.cache/
*.safetensors
*.gguf
*.gguf.*
*.bin
*.pt
*.pth
*.onnx
*.ckpt

# --- Metrics and reports (regenerated by pipeline) ---
metrics/**
!metrics/.gitkeep

# --- Python ---
venv/
.venv/
env/
.env/

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
*.manifest
pip-wheel-metadata/
__editable__*.pth
*.dist-info/

# --- Test / lint caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/

# --- IDE and editors ---
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~
.project
.pydevproject
*.sublime-project
*.sublime-workspace

# --- OS ---
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride

# --- Temp / backup ---
*.tmp
*.temp
*.bak
*.orig
*~

# --- Docker local (optional local overrides) ---
docker-compose.override.yml
docker-compose.override.yaml

# --- Agent / local tooling (if present) ---
agent-transcripts/
